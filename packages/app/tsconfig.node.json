{
  "extends": ["@electron-toolkit/tsconfig/tsconfig.node.json", "../../tsconfig.base.json"],
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/share/**/*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": { "@m/*": ["src/main/*"], "@p/*": ["src/preload/*"], "@s/*": ["src/share/*"] }
  }
}