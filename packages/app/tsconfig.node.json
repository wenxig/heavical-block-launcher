{
  "extends": ["@electron-toolkit/tsconfig/tsconfig.node.json", "../../tsconfig.base.json"],
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "types": ["electron-vite/node"],
    "paths": { "@m": ["./src/main"], "@p": ["./src/preload"] }
  }
}